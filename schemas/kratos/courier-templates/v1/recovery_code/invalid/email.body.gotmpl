<!doctype html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="color-scheme" content="light dark">
<meta name="supported-color-schemes" content="light dark">
<title>Account recovery attempted</title>
<!--[if mso]>
<style type="text/css">
  table { border-collapse: collapse; }
  .fallback-font { font-family: Arial, sans-serif !important; }
</style>
<![endif]-->
<style>
  @media (prefers-color-scheme: dark) {
    .email-bg { background-color: #1b1816 !important; }
    .card-bg { background-color: #272322 !important; }
    .card-border { border-color: #3a3532 !important; }
    .text-main { color: #f2efec !important; }
    .text-body { color: #d8d3ce !important; }
    .text-muted { color: #b8b2ac !important; }
    .code-box { background-color: #2f2547 !important; border-color: #4a3d78 !important; }
    .code-text { color: #d9c9ff !important; }
    .divider { border-top-color: #3a3532 !important; }
  }
  @media (max-width: 600px) {
    .container { width: 100% !important; }
    .px-pad { padding-left: 20px !important; padding-right: 20px !important; }
  }
</style>
</head>
<body style="margin:0; padding:0; background-color:#f5f5f4;" class="email-bg">
  <div style="display:none; max-height:0; overflow:hidden; mso-hide:all; font-size:1px; line-height:1px; color:#f5f5f4;">Account recovery was attempted with this email address.&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;</div>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f5f5f4; width:100%;" class="email-bg">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" class="container" style="width:600px; max-width:600px;">
          <tr>
            <td class="card-bg card-border" bgcolor="#ffffff" style="background-color:#ffffff; border:1px solid #e7e5e4; border-radius:12px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <!-- header -->
                <tr>
                  <td bgcolor="#9605f7" style="background-color:#9605f7; padding:22px 32px; border-radius:12px 12px 0 0;">
                    <table role="presentation" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="vertical-align:middle; padding-right:10px;">
                          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="PidgeIoT">
                    <path d="M16 7h.01"/>
                    <path d="M3.4 18H12a8 8 0 0 0 8-8V7a4 4 0 0 0-7.28-2.3L2 20"/>
                    <path d="m20 7 2 .5-2 .5"/>
                    <path d="M10 18v3"/>
                    <path d="M14 17.75V21"/>
                    <path d="M7 18a6 6 0 0 0 3.84-10.61"/>
                  </svg>
                        </td>
                        <td style="vertical-align:middle;">
                          <span style="font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size:22px; font-weight:700; color:#ffffff;">Pidge<span style="color:#00d3bb;">IoT</span></span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <!-- body -->
                <tr>
                  <td class="px-pad" style="padding:36px 32px 8px;">
                    <h1 class="text-main" style="margin:0 0 16px; font-size:20px; line-height:1.3; color:#1c1a19; font-weight:700; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">Account recovery attempted</h1>
                    <p class="text-body" style="margin:0 0 18px; font-size:15px; line-height:1.6; color:#3a3532; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">Hi,</p>
                    <p class="text-body" style="margin:0 0 24px; font-size:15px; line-height:1.6; color:#3a3532; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">Someone (possibly you) tried to recover access to a PidgeIoT account using this email address. We could not find an account registered with this address.</p>

                    <p class="text-muted" style="margin:24px 0 0; font-size:13px; line-height:1.6; color:#79746d; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">If this was you, check whether you signed up using a different email address.</p>
                    <p class="text-muted" style="margin:14px 0 28px; font-size:13px; line-height:1.6; color:#79746d; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">If this was not you, no action is needed &mdash; you can safely ignore this email.</p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:0 32px;">
                    <hr class="divider" style="border:none; border-top:1px solid #e7e5e4; margin:0;">
                  </td>
                </tr>
                <!-- footer -->
                <tr>
                  <td style="padding:20px 32px 28px;">
                    <p class="text-muted" style="margin:0 0 6px; font-size:12px; line-height:1.6; color:#a8a29c; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">This email was sent to {{ .To }} by PidgeIoT.</p>
                    <p class="text-muted" style="margin:0; font-size:12px; line-height:1.6; color:#a8a29c; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">&copy; Justin's Engineering Services, LLC. &middot; An open-source IoT platform built in Rust.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
